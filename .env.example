@"
# MCPilot Environment Configuration
# Copy this file to .env and fill in your values

# App
ENVIRONMENT=development
SECRET_KEY=change-me-before-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mcpilot

# LLM Provider (ollama | anthropic | bedrock)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# AWS (optional — for SageMaker deployment)
AWS_REGION=ap-south-1
AWS_SAGEMAKER_PHI_ENDPOINT=

# Data Retention (days)
AUDIT_LOG_RETENTION_DAYS=2555
PII_DATA_RETENTION_DAYS=365

# Data Controller (GDPR/DPDP)
DATA_CONTROLLER_NAME=MCPilot Technologies
DATA_CONTROLLER_CONTACT=privacy@mcpilot.in
"@ | Set-Content .env.example
